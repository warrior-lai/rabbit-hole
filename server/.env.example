# Copiá este archivo a server/.env y completá los valores.
# server/.env está en .gitignore: NO se commitea (no expone el secreto).

# Webhook de Discord donde llegan los reportes de debug (jugador expulsado, rejoin fallido, etc.)
# Crealo en: Discord -> Ajustes del canal -> Integraciones -> Webhooks -> Nuevo webhook -> Copiar URL
# Si lo dejás vacío, los reportes simplemente se desactivan (el juego funciona igual).
DISCORD_WEBHOOK_URL=
